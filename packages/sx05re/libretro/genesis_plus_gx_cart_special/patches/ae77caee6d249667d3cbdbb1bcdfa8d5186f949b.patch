+print_4:
+#if DEBUG_MODE
+	sprintf(error_str, "[%d] [%04X:%04X] DM %02X %02X -- %04X %04X %04X %04X\n",
+		v_counter,
+		(m68k.prev_pc>>16)&0xffff, m68k.prev_pc&0xffff,
