+
+static char *S68KDisasm(unsigned short (*NW)(), unsigned int (*NL)(), unsigned int hook_pc )
+{
+	int i;
+	unsigned short OPC;
+	static char Tmp_Str[64];
+
+	Dbg_Str[63] = 0;
+	Tmp_Str[63] = 0;
+
+	Next_Word = NW;
+	Next_Long = NL;
+
+	OPC = Next_Word();
+
+	sprintf(Dbg_Str, "Unknown Opcode%c", 0);
+
+	switch(OPC >> 12)
+	{
+		case 0:
+
+		if (OPC & 0x100)
+		{
+			if ((OPC & 0x038) == 0x8)
+			{
+				if (OPC & 0x080)
+					//MOVEP.z Ds,d16(Ad)
